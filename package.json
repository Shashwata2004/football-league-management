{
  "name": "football-league-management-system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "pnpm --filter @flms/shared build && pnpm --parallel --filter @flms/shared --filter @flms/backend --filter @flms/frontend run dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "prettier": "3.5.3",
    "typescript": "5.8.3"
  }
}
