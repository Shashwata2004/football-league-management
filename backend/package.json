{
  "name": "@flms/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:update-season-flow": "node scripts/apply-season-flow-migration.mjs",
    "db:fix-runtime-schema": "node scripts/apply-runtime-schema-hotfix.mjs",
    "db:add-set-piece-takers": "node scripts/apply-lineup-set-piece-takers.mjs",
    "db:add-yellow-card-rule": "node scripts/apply-yellow-card-suspension-rule.mjs",
    "db:rebalance-abilities": "tsx scripts/rebalance-existing-player-abilities.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@flms/shared": "workspace:*",
    "@supabase/supabase-js": "2.50.0",
    "cors": "2.8.5",
    "dotenv": "16.5.0",
    "express": "5.1.0",
    "helmet": "8.1.0",
    "morgan": "1.10.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/morgan": "1.9.9",
    "@types/node": "22.15.32",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
